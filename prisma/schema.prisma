// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
}

enum MembershipTier {
  BASIC
  STANDARD
  PREMIUM
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model User {
  id         String   @id @default(uuid())
  username   String   @unique
  email      String   @unique
  password   String
  role       Role
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Stats {
  id        String   @id @default(uuid())
  label     String   @unique
  value     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model About {
  id          Int      @id @default(1) // Always 1
  tag         String   @default("ABOUT THE BOSS GYM")
  heading     String   @default("WHERE CHAMPIONS ARE FORGED")
  highlight   String   @default("FORGED")
  description String   @db.Text
  buttonText  String   @default("START YOUR JOURNEY")
  buttonLink  String   @default("/contact")
  image       String?
  updatedAt   DateTime @updatedAt
}

model FounderMessage {
  id              Int      @id @default(1)
  title           String
  highlight       String   @default("FOUNDER")
  description     String   @db.Text
  founderName     String
  founderPosition String
  founderImage    String?
  updatedAt       DateTime @updatedAt
}

model Facilities {
  id          String @id @default(uuid())
  title       String
  description String
  image       String
}

model Service {
  id          String           @id @default(uuid())
  icon        String
  title       String
  description String
  image       String
  order       Int
  features    ServiceFeature[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now())
}

model ServiceFeature {
  id        String  @id @default(uuid())
  feature   String
  order     Int
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Trainer {
  id          String               @id @default(uuid())
  fullname    String
  position    String?
  experience  String?
  description String?
  image       String?
  order       Int                  @default(0)
  socialMedia TrainerSocialMedia[]
}

model TrainerSocialMedia {
  id        String   @id @default(uuid())
  title     String
  link      String
  icon      String?
  trainerId String?
  trainer   Trainer? @relation(fields: [trainerId], references: [id], onDelete: Cascade)
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  position  String
  image     String?
  comment   String   @db.Text
  createdAt DateTime @default(now())
}

model MembershipPlan {
  id           String         @id @default(cuid())
  tier         MembershipTier
  billingCycle BillingCycle
  price        Int // Price in NPR

  // Display information
  name         String // e.g., "Basic", "Standard", "Premium"
  description  String?
  isPopular    Boolean @default(false)
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  // Relation to features
  features PlanFeature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tier, billingCycle])
  @@index([tier])
  @@index([displayOrder])
}

model PlanFeature {
  id String @id @default(cuid())

  planId String
  plan   MembershipPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  // Feature text
  text       String // e.g., "Access to gym equipment", "Personal trainer sessions (2/month)"
  isIncluded Boolean @default(true) // true = checkmark, false = X mark

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId])
}

model GalleryImage {
  id        String   @id @default(uuid())
  imageUrl  String
  alt       String
  width     Int
  height    Int
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tags])
}

model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactInfo {
  id Int @id @default(1) // Singleton pattern - always 1

  // Phone
  phone      String
  phoneLabel String @default("Get in touch with our team for immediate assistance.")

  // Address
  address      String
  addressLabel String @default("Come visit our state-of-the-art facility in Pokhara.")

  // Email
  email      String
  emailLabel String @default("Send us an email and we'll respond within 24 hours.")

  // Social Media Links
  instagram String?
  facebook  String?
  linkedin  String?
  twitter   String?
  youtube   String?

  updatedAt DateTime @updatedAt
}

model MessageCategory {
  id        String    @id @default(uuid())
  name      String    @unique
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id         String   @id @default(uuid())
  name       String
  email      String
  phone      String
  message    String   @db.Text
  categoryId String
  category   MessageCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([categoryId])
  @@index([isRead])
  @@index([createdAt])
}

